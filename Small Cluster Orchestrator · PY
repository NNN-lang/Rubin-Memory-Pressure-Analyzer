def demo():
    print("\n" + "═" * 65)
    print("  RUBIN SMALL CLUSTER ORCHESTRATOR — DEMO")
    print("═" * 65)

    # 1. Build a 2-node NVL8 cluster (16 GPUs total)
    nodes = [
        RubinNodeConfig(node_id="node-0", n_gpus=8, vera_lpddr_tb=7.5, bf4_storage_tb=8.0),
        RubinNodeConfig(node_id="node-1", n_gpus=8, vera_lpddr_tb=7.5, bf4_storage_tb=8.0),
    ]
    cluster = ClusterConfig(nodes=nodes, multi_tenant=True)

    # 2. KV Tiering Plan for a 70B model, 200 concurrent users, 16k context
    print("\n[1] KV Cache Tiering Plan (70B model, 200 seqs, 16k context)")
    tiering = SmallClusterKVTiering(nodes[0], model_weight_gb=70.0,
                                     context_len=16384, n_layers=80,
                                     kv_bytes_per_token=0.5)
    plan = tiering.plan(n_active_seqs=200, avg_ctx_len=8192)
    for k, v in plan.items():
        print(f"   {k}: {v}")

    # 3. Parallelism planning
    print("\n[2] Optimal Parallelism Strategies")
    planner = AdaptiveParallelismPlanner()
    planner.print_plan(
        "Mixtral 8×22B (MoE)", model_params_b=140, n_gpus=16, n_nodes=2,
        inter_node_bw_gbs=100, is_moe=True, n_experts=8, top_k=2, context_len=4096)
    planner.print_plan(
        "Llama-3 70B (dense)", model_params_b=70, n_gpus=8, n_nodes=1,
        inter_node_bw_gbs=400, is_moe=False, context_len=8192)

    # 4. Multi-tenant scheduling
    print("\n[3] Multi-Tenant Scheduler (2 teams, 1 cluster)")
    sched = MultiTenantGpuScheduler(cluster)
    jobs = [
        WorkloadRequest("inf-001", "team_a", "llama70b", 4, priority=5, estimated_duration_s=3600),
        WorkloadRequest("train-001", "team_b", "mixtral", 8, priority=2, estimated_duration_s=7200),
        WorkloadRequest("inf-002", "team_a", "llama70b", 4, priority=4, estimated_duration_s=1800),
        WorkloadRequest("train-002", "team_b", "custom", 8, priority=1, estimated_duration_s=3600),
    ]
    for job in jobs:
        immediate = sched.submit(job)
        status = "RUNNING" if immediate else "QUEUED"
        print(f"   {job.request_id} (tenant={job.tenant_id}, GPUs={job.n_gpus_required}, "
              f"pri={job.priority}) → {status}")

    print(f"\n   Utilization: {json.dumps(sched.utilization_report(), indent=4)}")

    # 5. Power-aware consolidation
    print("\n[4] Power-Aware Node Consolidation")
    cons = PowerAwareConsolidationScheduler(cluster)
    cons.update_utilization("node-0", 75.0)
    cons.update_utilization("node-1", 18.0)   # underloaded → suspend candidate
    actions = cons.evaluate()
    for action in actions:
        print(f"   → {action['action']}: {action['node_id']} — {action.get('reason', '')}")
        if "estimated_power_saving_w" in action:
            print(f"     Power saving: {action['estimated_power_saving_w']} W")

    print(f"\n   Cluster status: {json.dumps(cons.status(), indent=4)}")

    print("\n" + "═" * 65 + "\n")


if __name__ == "__main__":
    logging.basicConfig(level=logging.WARNING)
    demo()


