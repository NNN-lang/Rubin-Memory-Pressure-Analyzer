class RubinAdoptionProfiler:
    """
    Unified entry point for assessing and accelerating Rubin migration.
    """

    SEVERITY_WEIGHTS = {"BLOCKER": 30, "MAJOR": 15, "MINOR": 5, "INFO": 0}
    MAX_DEDUCTIONS = 100

    def __init__(self):
        self.scanner = RubinCodeScanner()
        self.config_gen = RubinConfigGenerator()
        self.roofline = RubinRooflineEstimator()

    def profile_codebase(self, path: str) -> ReadinessReport:
        """Scan a Python codebase for Rubin readiness issues."""
        root = Path(path)
        if root.is_file():
            issues = self.scanner.scan_file(root)
        else:
            issues = self.scanner.scan_directory(root)

        # Score: start at 100, deduct per issue
        deductions = sum(self.SEVERITY_WEIGHTS.get(i.severity, 0) for i in issues)
        score = max(0.0, 100.0 - min(deductions, self.MAX_DEDUCTIONS))

        # Estimate speedup from various precision/optimization factors
        has_fp32 = any(i.category == "PRECISION" and "FP32" in i.message for i in issues)
        has_dp = any("DataParallel" in i.message for i in issues)
        has_cpu_copy = any("NVLink-C2C" in i.category for i in issues)

        # Current speedup estimate (Rubin vs Blackwell without code changes)
        current = 1.8
        if has_fp32:
            current *= 0.4    # fp32 severely limits Rubin utilization
        if has_dp:
            current *= 0.6

        # After-migration speedup estimate
        potential = 3.3       # baseline 3.3x from raw compute
        if not has_fp32:
            potential *= 1.4  # FP4/FP8 adds ~40% on top
        if not has_dp:
            potential *= 1.2  # topology-aware parallelism

        report = ReadinessReport(
            score=score,
            issues=issues,
            estimated_speedup_current=round(current, 2),
            estimated_speedup_potential=round(min(potential, 5.0), 2),
        )
        return report

    def generate_migration_report(self, path: str) -> str:
        """Full markdown migration report for a codebase."""
        report = self.profile_codebase(path)
        configs = self.config_gen.generate_all()

        lines = [
            "# Rubin Migration Report",
            f"**Generated:** {time.strftime('%Y-%m-%d %H:%M UTC')}",
            f"**Target Path:** `{path}`",
            "",
            "## Executive Summary",
            "",
            f"```",
            report.summary(),
            "```",
            "",
            "## Issues Found",
            "",
        ]

        for sev in ["BLOCKER", "MAJOR", "MINOR", "INFO"]:
            sev_issues = [i for i in report.issues if i.severity == sev]
            if not sev_issues:
                continue
            lines.append(f"### {sev} ({len(sev_issues)})")
            for issue in sev_issues:
                loc = f"`{issue.file}:{issue.line}`" if issue.file else ""
                lines += [
                    f"**[{issue.category}]** {issue.message}  ",
                    f"📍 {loc}  " if loc else "",
                    f"✅ **Fix:** {issue.fix}",
                    "",
                    "```python",
                    issue.code_patch,
                    "```",
                    "",
                ]

        lines += [
            "## Recommended Rubin Configuration",
            "",
            "### Environment Variables (NVLink 6)",
            "```bash",
        ]
        for k, v in configs["nvlink_environment"].items():
            lines.append(f"export {k}={v}")
        lines += [
            "```",
            "",
            "### vLLM Engine Args (Inference)",
            "```python",
            "engine_args = " + json.dumps(configs["vllm_engine_args"], indent=4),
            "```",
            "",
            "### Triton Kernel Tuning",
            "```python",
            "# autotune config for Rubin SM cluster arch",
            "triton_config = " + json.dumps(configs["triton_kernel_hints"], indent=4),
            "```",
            "",
            "## Roofline Quick-Check",
            "",
            "Example: Attention kernel at BF16 (typical LLM inference, 4096-token context):",
            "```",
        ]

        # Example attention roofline
        seq_len = 4096
        d_model = 8192
        flops = 4 * seq_len * seq_len * d_model      # rough QKV attention
        bytes_acc = 2 * seq_len * d_model * 2         # BF16
        att_roof = self.roofline.estimate(flops, bytes_acc, dtype="bfloat16")
        for k, v in att_roof.items():
            if k != "recommendations":
                lines.append(f"  {k}: {v}")
        lines += ["", "Recommendations:"]
        for rec in att_roof["recommendations"]:
            lines.append(f"  • {rec}")
        lines.append("```")

        return "\n".join(l for l in lines if l is not None)

    def print_report(self, path: str) -> None:
        rpt = self.generate_migration_report(path)
        print(rpt)


