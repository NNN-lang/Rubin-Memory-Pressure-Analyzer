class RubinConfigGenerator:
    """
    Generates optimized configuration files for Rubin deployment.
    """

    @staticmethod
    def nvlink_env() -> dict[str, str]:
        """Environment variables for Rubin NVLink 6 / NVL72."""
        return {
            "NCCL_NVLS_ENABLE": "1",
            "NCCL_MIN_NCHANNELS": "32",
            "NCCL_P2P_LEVEL": "NVL",
            "NCCL_CROSS_NIC": "0",
            "NCCL_SOCKET_IFNAME": "^lo,docker",
            "NCCL_BUFFSIZE": "8388608",      # 8 MB buffer for HBM4
            "CUDA_DEVICE_MAX_CONNECTIONS": "1",
            "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True,max_split_size_mb:512",
        }

    @staticmethod
    def torchrun_config(n_gpus: int = 72, n_nodes: int = 1) -> dict:
        """Optimal torchrun / torch.distributed config for Rubin NVL72."""
        return {
            "nproc_per_node": min(n_gpus, 72),
            "nnodes": n_nodes,
            "rdzv_backend": "etcd-v2",       # or "c10d" for simpler setups
            "max_restarts": 3,
            "monitor_interval": 5,
            "notes": {
                "tensor_parallel_size": 8,    # 1 NVSwitch group
                "pipeline_parallel_size": 9,  # 1 per NVSwitch
                "data_parallel_size": 1,
                "expert_parallel_size": 72,   # for MoE
            }
        }

    @staticmethod
    def vllm_engine_args() -> dict:
        """Optimal vLLM engine arguments for Rubin."""
        return {
            "tensor_parallel_size": 8,
            "pipeline_parallel_size": 1,
            "dtype": "float8",
            "kv_cache_dtype": "fp8_e5m2",      # matches BlueField-4 KV store format
            "max_model_len": 131072,            # 128k context
            "gpu_memory_utilization": 0.88,
            "enable_prefix_caching": True,
            "block_size": 32,                   # larger blocks for HBM4
            "swap_space": 64,                   # GB — uses Vera LPDDR5x via C2C
            "scheduler_delay_factor": 0.02,     # 20ms coalescing for FLOPS/W
            "max_num_seqs": 512,
            "max_num_batched_tokens": 65536,
            "notes": "Rubin HBM4 22TB/s — increase block_size for better BW utilization. "
                     "Set kv_cache_dtype=fp8 and enable BlueField-4 KV offload for "
                     "agentic workloads with long context chains.",
        }

    @staticmethod
    def triton_autotuning_config() -> dict:
        """Triton kernel config hints for Rubin SM cluster architecture."""
        return {
            "BLOCK_M": 128,         # Larger tiles to saturate HBM4 bandwidth
            "BLOCK_N": 256,
            "BLOCK_K": 64,
            "num_warps": 8,
            "num_stages": 5,        # More pipeline stages for HBM4 latency hiding
            "num_ctas": 1,          # CTA clusters (new in CUDA 13 / Rubin)
            "notes": "Rubin introduces SM cluster tiling. Set num_ctas > 1 to use "
                     "distributed shared memory across SM cluster. Expect 1.3-1.8x "
                     "speedup on memory-bound kernels vs Blackwell tuning.",
        }

    def generate_all(self) -> dict:
        return {
            "nvlink_environment": self.nvlink_env(),
            "torchrun": self.torchrun_config(),
            "vllm_engine_args": self.vllm_engine_args(),
            "triton_kernel_hints": self.triton_autotuning_config(),
        }


# ─────────────────────────────────────────────
#  Utilization Estimator (roofline model)
# ─────────────────────────────────────────────

class RubinRooflineEstimator:
    """
    Rubin roofline model for a given operation.
    Estimates actual vs theoretical throughput and identifies bottleneck.

    References: Williams et al. "Roofline: An Insightful Visual Performance Model" (2009)
    Adapted for Rubin HBM4 + NVFP4 specs.
    """

    # Rubin R200 hardware limits (per GPU)
    PEAK_FP4_TOPS: float = 50_000      # TFLOPS
    PEAK_FP8_TOPS: float = 25_000
    PEAK_BF16_TOPS: float = 12_500
    PEAK_FP32_TOPS: float = 3_125       # Estimated — non-sparse
    HBM4_BW_TBS: float = 22.0          # TB/s
    # Arithmetic intensity ridge point (FLOPS/Byte) for each precision
    RIDGE_FP4: float = PEAK_FP4_TOPS * 1e12 / (HBM4_BW_TBS * 1e12)   # ~2273 FLOP/B
    RIDGE_FP8: float = PEAK_FP8_TOPS * 1e12 / (HBM4_BW_TBS * 1e12)   # ~1136 FLOP/B
    RIDGE_BF16: float = PEAK_BF16_TOPS * 1e12 / (HBM4_BW_TBS * 1e12) # ~568 FLOP/B

    def estimate(
        self,
        flops: float,          # total FLOPs in the operation
        bytes_accessed: float, # total bytes read+written
        dtype: str = "bfloat16",
        measured_tflops: Optional[float] = None,
    ) -> dict:
        """
        Returns roofline analysis.
        """
        arithmetic_intensity = flops / max(bytes_accessed, 1)

        dtype_map = {
            "fp4": (self.PEAK_FP4_TOPS, self.RIDGE_FP4),
            "nvfp4": (self.PEAK_FP4_TOPS, self.RIDGE_FP4),
            "fp8": (self.PEAK_FP8_TOPS, self.RIDGE_FP8),
            "float8_e4m3fn": (self.PEAK_FP8_TOPS, self.RIDGE_FP8),
            "bfloat16": (self.PEAK_BF16_TOPS, self.RIDGE_BF16),
            "float16": (self.PEAK_BF16_TOPS, self.RIDGE_BF16),
            "float32": (self.PEAK_FP32_TOPS, float("inf")),
        }
        peak_tops, ridge = dtype_map.get(dtype.lower(), (self.PEAK_BF16_TOPS, self.RIDGE_BF16))

        # Roofline ceiling
        if arithmetic_intensity < ridge:
            bottleneck = "MEMORY_BOUND"
            ceiling_tflops = arithmetic_intensity * self.HBM4_BW_TBS
        else:
            bottleneck = "COMPUTE_BOUND"
            ceiling_tflops = peak_tops

        efficiency = (measured_tflops / ceiling_tflops * 100) if measured_tflops else None

        result = {
            "flops": flops,
            "bytes_accessed": bytes_accessed,
            "arithmetic_intensity_flops_per_byte": round(arithmetic_intensity, 1),
            "ridge_point_flops_per_byte": round(ridge, 1),
            "bottleneck": bottleneck,
            "ceiling_tflops": round(ceiling_tflops, 1),
            "peak_compute_tflops": peak_tops,
            "hbm4_bandwidth_tbs": self.HBM4_BW_TBS,
            "dtype": dtype,
        }
        if efficiency is not None:
            result["measured_tflops"] = measured_tflops
            result["efficiency_pct"] = round(efficiency, 1)
            result["wasted_headroom_tflops"] = round(ceiling_tflops - measured_tflops, 1)

        # Recommendations
        recs = []
        if bottleneck == "MEMORY_BOUND":
            recs.append(f"AI = {arithmetic_intensity:.0f} FLOP/B < ridge {ridge:.0f}. "
                       "Increase tile size / fuse ops to improve data reuse.")
            if dtype in ("float16", "bfloat16"):
                recs.append("Switch to FP8 → halves bytes_accessed, doubles effective AI → "
                           f"could push past ridge to compute-bound at AI > {self.RIDGE_FP8:.0f}.")
            if dtype not in ("fp4", "nvfp4"):
                recs.append("For maximum Rubin utilization, target NVFP4 (AI > 2273 FLOP/B required).")
        else:
            recs.append("Compute-bound — good. Focus on reducing launch overhead and "
                       "SM cluster scheduling efficiency.")

        result["recommendations"] = recs
        return result


