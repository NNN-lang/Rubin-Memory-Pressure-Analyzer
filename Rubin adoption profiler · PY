# ─────────────────────────────────────────────
#  Readiness Scoring
# ─────────────────────────────────────────────

@dataclass
class ReadinessIssue:
    severity: str           # "BLOCKER", "MAJOR", "MINOR", "INFO"
    category: str           # e.g. "PRECISION", "MEMORY", "NVLINK", "KERNEL"
    message: str
    file: str = ""
    line: int = 0
    fix: str = ""           # Actionable fix description
    code_patch: str = ""    # Suggested code change


@dataclass
class ReadinessReport:
    score: float = 0.0          # 0–100, 100 = fully Rubin-optimized
    issues: list[ReadinessIssue] = field(default_factory=list)
    estimated_speedup_current: float = 1.0   # vs Blackwell without changes
    estimated_speedup_potential: float = 1.0 # vs Blackwell after fixes

    def summary(self) -> str:
        blockers = [i for i in self.issues if i.severity == "BLOCKER"]
        major = [i for i in self.issues if i.severity == "MAJOR"]
        return (
            f"Rubin Readiness Score: {self.score:.0f}/100\n"
            f"  BLOCKERS: {len(blockers)}  |  MAJOR: {len(major)}  |  "
            f"MINOR: {len(self.issues) - len(blockers) - len(major)}\n"
            f"  Est. speedup without changes:  {self.estimated_speedup_current:.1f}x vs Blackwell\n"
            f"  Est. speedup after migration:  {self.estimated_speedup_potential:.1f}x vs Blackwell\n"
        )


# ─────────────────────────────────────────────
#  Code Scanner (static analysis of Python source)
# ─────────────────────────────────────────────

class RubinCodeScanner:
    """
    Scans Python source files for Rubin anti-patterns.
    Uses AST analysis — no GPU required.
    """

    # Patterns that prevent full Rubin utilization
    ANTIPATTERNS = [
        {
            "pattern": "torch.float32",
            "severity": "MAJOR",
            "category": "PRECISION",
            "message": "FP32 computation found — Rubin peak is NVFP4 (50 PFLOPs). "
                       "FP32 uses only ~12.5% of peak compute.",
            "fix": "Use torch.float8_e4m3fn or torch.float16 for inference. "
                   "For Rubin NVFP4: use transformer_engine or CUTLASS FP4 kernels.",
            "patch": "# Replace:\n# model = model.to(torch.float32)\n"
                     "# With (for Rubin FP8 path):\n"
                     "import transformer_engine.pytorch as te\n"
                     "model = te.fp8_autocast(enabled=True)(model)\n"
                     "# Or for NVFP4 (requires CUDA 13+ on Rubin):\n"
                     "# model = model.to(torch.float4)  # planned API",
        },
        {
            "pattern": "torch.nn.DataParallel",
            "severity": "BLOCKER",
            "category": "PARALLELISM",
            "message": "DataParallel detected — does not support NVLink 6 topology-aware "
                       "communication. Will cause severe NVLink contention on NVL72.",
            "fix": "Migrate to torch.distributed with NCCL + NVLink topology groups. "
                   "Use device_mesh API for Rubin's NVSwitch-aware groups.",
            "patch": "# Replace DataParallel with:\n"
                     "from torch.distributed.device_mesh import init_device_mesh\n"
                     "# For Rubin NVL72 (72 GPUs, 9 NVSwitch groups of 8):\n"
                     "mesh = init_device_mesh('cuda', (9, 8), mesh_dim_names=('switch', 'gpu'))\n"
                     "from torch.distributed.tensor.parallel import parallelize_module\n"
                     "model = parallelize_module(model, mesh)",
        },
        {
            "pattern": "torch.cuda.memory.caching_allocator",
            "severity": "MINOR",
            "category": "MEMORY",
            "message": "Default CUDA caching allocator may not leverage HBM4's "
                       "22 TB/s bandwidth. Large allocations may fragment.",
            "fix": "Use expandable_segments=True and set PYTORCH_CUDA_ALLOC_CONF "
                   "for Rubin HBM4 (288 GB, larger pages possible).",
            "patch": "import os\n"
                     "os.environ['PYTORCH_CUDA_ALLOC_CONF'] = (\n"
                     "    'expandable_segments:True,'\n"
                     "    'max_split_size_mb:512,'\n"
                     "    'garbage_collection_threshold:0.8'\n"
                     ")",
        },
        {
            "pattern": ".cpu()",
            "severity": "MAJOR",
            "category": "NVLINK_C2C",
            "message": "Explicit .cpu() transfer detected. On Rubin, Vera CPU and Rubin GPU "
                       "share a unified address space via NVLink-C2C (1.8 TB/s). "
                       "Unnecessary .cpu() copies waste 3-5 µs per call.",
            "fix": "Use torch.empty(..., device='cpu', pin_memory=True) or rely on "
                   "NVLink-C2C unified memory. Remove explicit .cpu() calls in hot paths.",
            "patch": "# Instead of:\n# tensor = gpu_tensor.cpu()\n"
                     "# On Rubin Vera+GPU systems, use unified memory:\n"
                     "# tensor = gpu_tensor  # already accessible from Vera CPU via C2C\n"
                     "# Or pin CPU buffer for zero-copy:\n"
                     "buf = torch.empty(shape, device='cpu', pin_memory=True)\n"
                     "buf.copy_(gpu_tensor, non_blocking=True)",
        },
        {
            "pattern": "autocast",
            "severity": "INFO",
            "category": "PRECISION",
            "message": "torch.autocast found — good. Verify dtype='bfloat16' or "
                       "'float8_e4m3fn' for Rubin. 'float16' is valid but not optimal.",
            "fix": "Prefer bfloat16 (better numerical range) or FP8 for Rubin.",
            "patch": "# Ensure:\nwith torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n"
                     "    output = model(input)\n"
                     "# For FP8 (Rubin fully supported):\n"
                     "# import transformer_engine.pytorch as te\n"
                     "# with te.fp8_autocast(enabled=True): ...",
        },
        {
            "pattern": "nccl",
            "severity": "INFO",
            "category": "NVLINK",
            "message": "NCCL usage detected. Ensure NCCL >= 2.22 for NVLink 6 support. "
                       "Set NCCL_NVLS_ENABLE=1 for NVLink SHARP (in-switch reductions).",
            "fix": "Set environment: NCCL_NVLS_ENABLE=1, NCCL_MIN_NCHANNELS=32 on Rubin.",
            "patch": "import os\n"
                     "# Rubin NVLink 6 NCCL tuning:\n"
                     "os.environ.update({\n"
                     "    'NCCL_NVLS_ENABLE': '1',          # NVLink SHARP reductions\n"
                     "    'NCCL_MIN_NCHANNELS': '32',       # More channels for HBM4\n"
                     "    'NCCL_P2P_LEVEL': 'NVL',          # Prefer NVLink P2P\n"
                     "    'NCCL_CROSS_NIC': '0',            # Prefer NVLink over IB\n"
                     "})",
        },
    ]

    def scan_file(self, path: Path) -> list[ReadinessIssue]:
        issues = []
        try:
            source = path.read_text(encoding="utf-8", errors="replace")
        except Exception as e:
            log.warning("Cannot read %s: %s", path, e)
            return issues

        lines = source.splitlines()
        for ap in self.ANTIPATTERNS:
            pat = ap["pattern"]
            for lineno, line in enumerate(lines, 1):
                if pat in line:
                    issues.append(ReadinessIssue(
                        severity=ap["severity"],
                        category=ap["category"],
                        message=ap["message"],
                        file=str(path),
                        line=lineno,
                        fix=ap["fix"],
                        code_patch=ap["patch"],
                    ))
                    break  # one issue per pattern per file

        return issues

    def scan_directory(self, root: Path, extensions=(".py",)) -> list[ReadinessIssue]:
        all_issues = []
        for p in root.rglob("*"):
            if p.suffix in extensions and p.is_file():
                all_issues.extend(self.scan_file(p))
        return all_issues


